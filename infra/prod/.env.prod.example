# Public port for Monopoly frontend on server IP.
# With existing CRM on :80, keep Monopoly on another port, e.g. 8081.
MONO_PUBLIC_PORT=8081

POSTGRES_DB=monopoly_sds
POSTGRES_USER=monopoly_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=30
APP_TIMEZONE=Europe/Moscow
PASSWORD_RESET_TTL_MINUTES=60

# If using direct port access:
# PASSWORD_RESET_LINK_BASE_URL=http://31.130.135.202:8081/auth/reset
PASSWORD_RESET_LINK_BASE_URL=http://31.130.135.202:8081/auth/reset

# CORS list for browser requests to backend.
# For separate port deployment, include Monopoly frontend origin only.
CORS_ORIGINS=http://31.130.135.202:8081

# Frontend build args:
# For separate port deployment, reverse-proxy API through same origin as /api
VITE_API_BASE_URL=/api
VITE_BASE_PATH=/
